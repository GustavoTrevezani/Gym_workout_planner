generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String
  height          Float?
  weight          Float?
  age             Int?
  workouts        Workout[]
  workoutSessions WorkoutSession[]
  bodyMeasurements BodyMeasurement[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Workout {
  id              Int              @id @default(autoincrement())
  name            String
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  days            WorkoutDay[]
  workoutSessions WorkoutSession[]
}

model MuscleGroup {
  id        Int              @id @default(autoincrement())
  name      String
  subGroups MuscleSubGroup[]
}

model MuscleSubGroup {
  id            Int         @id @default(autoincrement())
  name          String
  muscleGroupId Int
  exercises     Exercise[]
  muscleGroup   MuscleGroup @relation(fields: [muscleGroupId], references: [id])
}

model Exercise {
  id               Int               @id @default(autoincrement())
  name             String
  muscleSubGroupId Int
  muscleSubGroup   MuscleSubGroup    @relation(fields: [muscleSubGroupId], references: [id])
  workoutExercises WorkoutExercise[]
  workoutSets      WorkoutSet[]
}

model WorkoutExercise {
  id            Int        @id @default(autoincrement())
  workoutDayId  Int
  exerciseId    Int
  sets          Int
  reps          Int
  restTime      Int
  order         Int
  supersetGroup Int?
  exercise      Exercise   @relation(fields: [exerciseId], references: [id])
  workoutDay    WorkoutDay @relation(fields: [workoutDayId], references: [id])
}

model WorkoutDay {
  id        Int               @id @default(autoincrement())
  day       WeekDay
  workoutId Int
  workout   Workout           @relation(fields: [workoutId], references: [id])
  exercises WorkoutExercise[]

  @@unique([workoutId, day])
}

model WorkoutSession {
  id         Int          @id @default(autoincrement())
  workoutId  Int
  userId     Int
  startedAt  DateTime
  finishedAt DateTime?
  user       User         @relation(fields: [userId], references: [id])
  workout    Workout      @relation(fields: [workoutId], references: [id])
  sets       WorkoutSet[]

  @@index([userId, startedAt])
}

model WorkoutSet {
  id         Int            @id @default(autoincrement())
  sessionId  Int
  exerciseId Int
  sets       Json
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  session    WorkoutSession @relation(fields: [sessionId], references: [id])
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model BodyMeasurement {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  chest            Float?
  shoulders        Float?
  neck             Float?

  bicepsLeft       Float?
  bicepsRight      Float?
  tricepsLeft      Float?
  tricepsRight     Float?
  forearmLeft      Float?
  forearmRight     Float?

  abdomen          Float?
  waist            Float?
  glutes           Float?

  thighLeft        Float?
  thighRight       Float?
  calfLeft         Float?
  calfRight        Float?

  height           Float?
  weight           Float?
  bodyFatPercentage Float?
    
  createdAt     DateTime @default(now())
}
